{
  "id": "aws_credential_misuse",
  "name": "Datadog Lab Replay - AWS Credential Misuse",
  "type": "log alert",
  "scenario_id": "aws_iam_key_misuse",
  "severity": "high",
  "query": "logs(\"source:test-harness @synthetic:true @purpose:detection-rule-validation @scenario:aws_iam_key_misuse\").index(\"*\").rollup(\"count\").last(\"10m\") >= 1",
  "message": "Synthetic AWS credential misuse replay observed. This monitor only fires on test-harness events.",
  "tags": ["datadog-detection-lab", "test-harness", "synthetic", "aws-iam-key-misuse"],
  "options": {
    "include_tags": true,
    "notify_no_data": false,
    "renotify_interval": 0,
    "on_missing_data": "default",
    "thresholds": { "critical": 1 }
  },
  "triage": "Review API sequence, actor identity, source geography, access-key age, and follow-on privilege changes.",
  "evidence_refs": ["cloud-credential-misuse", "synthetic-log-replay"]
}

